# ──────────────────────────────────────────────────────────────────────
# ProductSense — environment variables
# Copy to .env and fill in. Never commit .env.
# ──────────────────────────────────────────────────────────────────────

# ─── Supabase ────────────────────────────────────────────────────────
# Project URL and anon key are safe to expose to the web client.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service role key bypasses RLS. Backend only. Never to the web client.
SUPABASE_SERVICE_ROLE_KEY=
# Direct postgres connection for the LangGraph checkpointer + Store.
# Get from Supabase dashboard → Settings → Database → Connection string
# (Transaction pooler, port 6543). Leave blank to run stateless (today's
# behavior — no durable graph state, no cross-turn resume).
SUPABASE_DB_URL=

# ─── Vertex AI / Gemini ──────────────────────────────────────────────
# Auth via `gcloud auth application-default login` for dev,
# or service account key (GOOGLE_APPLICATION_CREDENTIALS) for deployed.
GCP_PROJECT_ID=
VERTEX_LOCATION=us-east5

# Model IDs — verify against latest Vertex docs at scaffold time
MAYA_MODEL=gemini-3.1-pro-preview
SUBAGENT_MODEL=gemini-3.1-flash-lite-preview

# ─── Firecrawl ───────────────────────────────────────────────────────
FIRECRAWL_API_KEY=

# ─── Backend API ─────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:5173

# ─── MCP Server ──────────────────────────────────────────────────────
MCP_HOST=0.0.0.0
MCP_PORT=8001
MCP_PUBLIC_URL=http://localhost:8001

# ─── Web app (Vite) ──────────────────────────────────────────────────
# Vars exposed to the browser must be prefixed with VITE_
VITE_API_URL=http://localhost:8000
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Asset manager: GitHub OAuth (optional) ──────────────────────────
# Register an OAuth App at https://github.com/settings/developers
# Callback URL: http://localhost:5176/integrations/github/callback
# Leave blank to keep the integration disabled (the Settings UI will
# show a "not configured" state).
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:5176/integrations/github/callback

# Fernet key for encrypting GitHub access tokens at rest.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave blank in dev (tokens stored plaintext); REQUIRED in production.
ASSET_ENCRYPTION_KEY=

# ─── LangSmith tracing (optional) ────────────────────────────────────
# Free observability: every Maya turn, sub-agent call, and tool dispatch
# auto-traces to https://smith.langchain.com when LANGSMITH_TRACING=true.
# Sign up at https://smith.langchain.com and create a PAT at
# https://smith.langchain.com/settings to get a key (lsv2_pt_...).
# Leave LANGSMITH_API_KEY blank to disable tracing entirely (no crash).
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=productsense
# LANGSMITH_ENDPOINT — only set for regional SaaS (EU/APAC/AWS); defaults to GCP US
# LANGSMITH_WORKSPACE_ID — only set if your PAT spans multiple workspaces
